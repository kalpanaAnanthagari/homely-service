# Node.js 20+ required (see package.json "engines" and .nvmrc)

# PostgreSQL (Neon, Vercel Postgres, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth0 — create a Regular Web Application (not SPA) at https://manage.auth0.com
# In Application → Settings, these must match APP_BASE_URL exactly (scheme, host, port):
#   Allowed Callback URLs:  http://localhost:3000/auth/callback
#   Allowed Logout URLs:    http://localhost:3000
#   Allowed Web Origins:    http://localhost:3000
# If you open the site as http://127.0.0.1:3000, set APP_BASE_URL to that host and add
# the same three URL types with 127.0.0.1 (Auth0 treats localhost vs 127.0.0.1 as different).
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="..."
AUTH0_CLIENT_SECRET="..."
# Generate: openssl rand -hex 32
AUTH0_SECRET=""
APP_BASE_URL="http://localhost:3000"
